---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="页面未找到" description="该页面不存在或已被移动。">
  <main class="page">
    <section class="notfound">
      <p class="notfound__code">404</p>
      <h1 class="page-title">页面走丢了</h1>
      <p class="lead">
        你访问的页面不存在或已被移动。可以回到首页,或从学习路线重新开始。
      </p>
      <div class="toolbar">
        <a class="button button--primary" href="/">返回首页</a>
        <a class="button" href="/roadmap/">查看路线</a>
        <a class="button" href="/search/">搜索内容</a>
      </div>
    </section>
  </main>
</BaseLayout>
